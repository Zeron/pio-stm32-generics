{
  "build": {
    "core": "stm32",
    "cpu": "cortex-m3",
    "extra_flags": "-DSTM32F100xB -DSTM32F1",
    "f_cpu": "24000000L",
    "mcu": "STM32F100R4Hx",
    "product_line": "STM32F100xB",
    "variant": "STM32F1xx/F100R(4-6)H"
  },
  "debug": {
    "jlink_device": "stm32f100r4",
    "openocd_target": "stm32f1x",
    "svd_path": "STM32F100.svd"
  },
  "frameworks": [
    "arduino",
    "cmsis",
    "stm32cube",
    "libopencm3"
  ],
  "name": "STM32F100R4Hx (4k RAM 16k Flash)",
  "upload": {
    "maximum_ram_size": 4096,
    "maximum_size": 16384,
    "protocol": "serial",
    "protocols": [
      "blackmagic",
      "dfu",
      "serial",
      "stlink",
      "jlink",
      "cmsis-dap"
    ]
  },
  "url": "https://www.st.com/en/microcontrollers-microprocessors/stm32f100r4.html",
  "vendor": "ST"
}
{
  "build": {
    "core": "stm32",
    "cpu": "cortex-m3",
    "extra_flags": "-DSTM32F100xB -DSTM32F1",
    "f_cpu": "24000000L",
    "mcu": "STM32F100C8Tx",
    "product_line": "STM32F100xB",
    "variant": "STM32F1xx/F100C(8-B)T"
  },
  "debug": {
    "jlink_device": "stm32f100c8",
    "openocd_target": "stm32f1x",
    "svd_path": "STM32F100.svd"
  },
  "frameworks": [
    "arduino",
    "cmsis",
    "stm32cube",
    "libopencm3"
  ],
  "name": "STM32F100C8Tx (8k RAM 64k Flash)",
  "upload": {
    "maximum_ram_size": 8192,
    "maximum_size": 65536,
    "protocol": "serial",
    "protocols": [
      "blackmagic",
      "dfu",
      "serial",
      "stlink",
      "jlink",
      "cmsis-dap"
    ]
  },
  "url": "https://www.st.com/en/microcontrollers-microprocessors/stm32f100c8.html",
  "vendor": "ST"
}
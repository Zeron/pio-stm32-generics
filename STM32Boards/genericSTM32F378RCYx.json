    "extra_flags": "-DSTM32F378xx -DSTM32F3",
    "f_cpu": "72000000L",
    "mcu": "STM32F378RCYx",
    "product_line": "STM32F378xx",
    "variant": "STM32F3xx/F378RC(T-Y)"
  },
  "debug": {

{
  "build": {
    "core": "stm32",
    "cpu": "cortex-m0plus",
    "extra_flags": "-DSTM32L010x8 -DSTM32L",
    "f_cpu": "32000000L",
    "mcu": "STM32L010R8Tx",
    "product_line": "STM32L010x8",
    "variant": "STM32L0xx/L010R8T"
  },
  "debug": {
    "jlink_device": "stm32l010r8",
    "openocd_target": "stm32xl",
    "svd_path": "STM32L0x0.svd"
  },
  "frameworks": [
    "arduino",
    "cmsis",
    "stm32cube",
    "libopencm3"
  ],
  "name": "STM32L010R8Tx (8k RAM 64k Flash)",
  "upload": {
    "maximum_ram_size": 8192,
    "maximum_size": 65536,
    "protocol": "serial",
    "protocols": [
      "blackmagic",
      "dfu",
      "serial",
      "stlink",
      "jlink",
      "cmsis-dap"
    ]
  },
  "url": "https://www.st.com/en/microcontrollers-microprocessors/stm32l010r8.html",
  "vendor": "ST"
}